# ─── Dependencies ────────────────────────────────────────────────────────────
# node_modules is excluded; package-lock.json is intentionally committed so
# anyone cloning the repo gets an exact, reproducible dependency tree.
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js build output ────────────────────────────────────────────────────
.next/
out/

# ─── Production build ────────────────────────────────────────────────────────
build/
dist/

# ─── Environment variables ───────────────────────────────────────────────────
# Never commit secrets or API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ─── OS & editor artifacts ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ─── IDEs & editors ──────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── Alternate package manager locks (not used by this project) ──────────────
# This project uses npm — yarn.lock and pnpm-lock.yaml are excluded if present
yarn.lock
pnpm-lock.yaml

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pem
.cache/
.turbo/
